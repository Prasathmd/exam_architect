# Exam-Architect AI — copy to .env and set values

# Database: use database "postgres", schema "exam_architect"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
DATABASE_SCHEMA=exam_architect

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM: openai or gemini (use gemini to avoid OpenAI quota issues)
LLM_PROVIDER=gemini
OPENAI_API_KEY=
# Paste your Gemini API key from Google AI Studio (Create API key → Copy key)
GOOGLE_API_KEY=AIzaSyDTWSstTixWOg90xxvuk_poEtYWE8GHiyk

# Optional
# MAX_UPLOAD_SIZE_MB=50
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
