# Exam-Architect AI — copy to .env and set values

# Database: use database "postgres", schema "exam_architect"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
DATABASE_SCHEMA=exam_architect

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM: gemini
LLM_PROVIDER=gemini
# Paste your key from https://aistudio.google.com/app/api-keys (either variable works)
GOOGLE_API_KEY=AIzaSyDTWSstTixWOg90xxvuk_poEtYWE8GHiyk


# Optional
MAX_UPLOAD_SIZE_MB=1024
# Use larger chunk size for longer documents (default 1200)
CHUNK_SIZE=1200
# Use larger overlap for longer documents (default 200)
CHUNK_OVERLAP=200
